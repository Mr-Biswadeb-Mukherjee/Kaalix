{
  "name": "amon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The god of knowledge and secrecy — now weaponized for offensive security and password cracking operations.",
  "packageManager": "pnpm@8.10.5",
  "scripts": {
    "dev:frontend": "pnpm --filter amon-frontend dev",
    "dev:backend": "pnpm --filter amon-backend dev",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "install-all": "pnpm install",
    "dev": "concurrently \"pnpm --filter amon-frontend dev\" \"pnpm --filter amon-backend dev\"",
    "start": "electron .",
    "start:all": "pnpm -r start",
    "electron": "electron .",
    "pack:linux": "electron-builder --linux AppImage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/official-biswadeb941/Amon"
  },
  "keywords": [
    "red-teaming",
    "cybersecurity",
    "offensive-security",
    "malware",
    "toolkit",
    "amon",
    "password-cracking"
  ],
  "author": "Biswadeb Mukherjee",
  "license": "Non-Shareable",
  "bugs": {
    "url": "https://github.com/official-biswadeb941/Amon/issues"
  },
  "homepage": "https://github.com/official-biswadeb941/Amon",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@fortawesome/free-solid-svg-icons": "^7.0.1",
    "@fortawesome/react-fontawesome": "^3.0.2",
    "@mui/icons-material": "^7.3.2",
    "@types/react": "^19.1.8",
    "@vitejs/plugin-react": "^4.6.0",
    "axios": "^1.13.5",
    "canvas": "^3.2.0",
    "captcha-canvas": "^2.4.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "depcheck": "^1.4.7",
    "electron": "^37.5.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "express": "^5.1.0",
    "globals": "^16.3.0",
    "intl-tel-input": "^25.10.12",
    "jest": "^30.1.3",
    "jsdiff": "^1.1.1",
    "libphonenumber-js": "^1.12.22",
    "lucide-react": "^0.542.0",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.0.3",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react-avatar": "^5.0.4",
    "react-avatar-editor": "^13.0.2",
    "react-modal": "^3.16.3",
    "react-phone-input-2": "^2.15.1",
    "sanitize-html": "^2.17.0",
    "speakeasy": "^2.0.0",
    "svg-captcha": "^1.4.0",
    "uuid": "^11.1.0",
    "validator": "^13.15.15",
    "vite": "^7.0.4",
    "wait-on": "^8.0.5",
    "winston": "^3.18.3",
    "winston-transport": "^4.9.0"
  },
  "build": {
    "appId": "com.amon.com",
    "productName": "AMON",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "backend/**/*"
    ],
    "files": [
      "index.js",
      "preload.js",
      "backend/**/*",
      "frontend/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "assets/LOGO.png"
    },
    "mac": {
      "category": "private.app.com"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "file-type": "^21.0.0",
    "framer-motion": "^12.23.11",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.14.2",
    "node-os-utils": "^1.3.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^5.5.1",
    "react-google-recaptcha": "^3.1.0",
    "react-router-dom": "^7.7.0",
    "redis": "^5.8.0",
    "sharp": "^0.34.4",
    "systeminformation": "^5.27.7",
    "ws": "^8.18.3"
  }
}
