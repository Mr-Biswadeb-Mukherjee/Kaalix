{
  "name": "amon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The god of knowledge and secrecy — now weaponized for offensive security and password cracking operations.",
  "packageManager": "pnpm@8.10.5",
  "scripts": {
    "dev:frontend": "pnpm --filter amon-ui dev",
    "dev:backend": "pnpm --filter amon-backend dev",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "install-all": "pnpm install",
    "dev": "concurrently \"pnpm --filter amon-ui dev\" \"pnpm --filter amon-backend dev\"",
    "start": "electron .",
    "start:all": "pnpm -r start",
    "electron": "electron .",
    "pack:linux": "electron-builder --linux AppImage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/official-biswadeb941/Amon"
  },
  "keywords": [
    "red-teaming",
    "cybersecurity",
    "offensive-security",
    "malware",
    "toolkit",
    "amon",
    "password-cracking"
  ],
  "author": "Biswadeb Mukherjee",
  "license": "Non-Shareable",
  "bugs": {
    "url": "https://github.com/official-biswadeb941/Amon/issues"
  },
  "homepage": "https://github.com/official-biswadeb941/Amon",
  "devDependencies": {
    "axios": "^1.11.0",
    "canvas": "^3.1.2",
    "captcha-canvas": "^2.4.1",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "jest": "^30.1.1",
    "node-fetch": "^3.3.2",
    "react-avatar": "^5.0.4",
    "react-avatar-editor": "^13.0.2",
    "react-modal": "^3.16.3",
    "svg-captcha": "^1.4.0",
    "uuid": "^11.1.0",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.amon.com",
    "productName": "AMON",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "backend/**/*"
    ],
    "files": [
      "index.js",
      "preload.js",
      "backend/**/*",
      "frontend/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "assets/LOGO.png"
    },
    "mac": {
      "category": "private.app.com"
    },
    "win": {
      "target": "nsis"
    }
  }
}
